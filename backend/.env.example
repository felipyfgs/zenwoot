# ==============================================
# wzap Application Configuration
# ==============================================

# Application
PORT=8080
SERVER_HOST=0.0.0.0
API_KEY=wzap-secret-apikey-123
JWT_SECRET=change-me-in-production
LOG_LEVEL=debug
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgres://wzap:wzap123@localhost:5432/wzap?sslmode=disable
POSTGRES_DB=wzap
POSTGRES_USER=wzap
POSTGRES_PASSWORD=wzap123
POSTGRES_PORT=5432

# Storage (MinIO)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123
MINIO_BUCKET=wzap-media
MINIO_USE_SSL=false

# Queue (NATS)
NATS_URL=nats://localhost:4222

# WhatsApp
WA_LOG_LEVEL=INFO

# Webhooks
GLOBAL_WEBHOOK_URL=https://your-domain.com/webhooks
