# Zenwoot Backend — copy to .env and adjust

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080

DATABASE_URL=postgres://zenwoot:zenwoot@localhost:5432/zenwoot?sslmode=disable

REDIS_ADDR=localhost:6379
